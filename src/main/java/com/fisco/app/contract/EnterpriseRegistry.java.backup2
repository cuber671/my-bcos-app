                (BigInteger) results.get(1).getValue()
                );
    }

    public Tuple1<Boolean> getUpdateEnterpriseStatusOutput(TransactionReceipt transactionReceipt) {
        String data = transactionReceipt.getOutput();
        final Function function = new Function(FUNC_UPDATEENTERPRISESTATUS, 
                Arrays.<Type>asList(), 
                Arrays.<TypeReference<?>>asList(new TypeReference<Bool>() {}));
        List<Type> results = this.functionReturnDecoder.decode(data, function.getOutputParameters());
        return new Tuple1<Boolean>(

                (Boolean) results.get(0).getValue()
                );
    }

    public static EnterpriseRegistry load(String contractAddress, Client client,
            CryptoKeyPair credential) {
        return new EnterpriseRegistry(contractAddress, client, credential);
    }

    public static EnterpriseRegistry deploy(Client client, CryptoKeyPair credential) throws
            ContractException {
        return deploy(EnterpriseRegistry.class, client, credential, getBinary(client.getCryptoSuite()), getABI(), null, null);
    }

    public static class Enterprise extends DynamicStruct {
        public String name;

        public String creditCode;

        public String enterpriseAddress;

        public BigInteger role;

        public BigInteger status;

        public BigInteger creditRating;

        public BigInteger creditLimit;

        public BigInteger registeredAt;

        public BigInteger updatedAt;

        public Boolean exists;

        public Enterprise(Utf8String name, Utf8String creditCode, Utf8String enterpriseAddress,
                Uint8 role, Uint8 status, Uint256 creditRating, Uint256 creditLimit,
                Uint256 registeredAt, Uint256 updatedAt, Bool exists) {
            super(name,creditCode,enterpriseAddress,role,status,creditRating,creditLimit,registeredAt,updatedAt,exists);
            this.name = name.getValue();
            this.creditCode = creditCode.getValue();
            this.enterpriseAddress = enterpriseAddress.getValue();
            this.role = role.getValue();
            this.status = status.getValue();
            this.creditRating = creditRating.getValue();
            this.creditLimit = creditLimit.getValue();
            this.registeredAt = registeredAt.getValue();
            this.updatedAt = updatedAt.getValue();
            this.exists = exists.getValue();
        }

        public Enterprise(String name, String creditCode, String enterpriseAddress, BigInteger role,
                BigInteger status, BigInteger creditRating, BigInteger creditLimit,
                BigInteger registeredAt, BigInteger updatedAt, Boolean exists) {
            super(new org.fisco.bcos.sdk.v3.codec.datatypes.Utf8String(name),new org.fisco.bcos.sdk.v3.codec.datatypes.Utf8String(creditCode),new org.fisco.bcos.sdk.v3.codec.datatypes.Utf8String(enterpriseAddress),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint8(role),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint8(status),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint256(creditRating),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint256(creditLimit),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint256(registeredAt),new org.fisco.bcos.sdk.v3.codec.datatypes.generated.Uint256(updatedAt),new org.fisco.bcos.sdk.v3.codec.datatypes.Bool(exists));
            this.name = name;
            this.creditCode = creditCode;
            this.enterpriseAddress = enterpriseAddress;
            this.role = role;
            this.status = status;
            this.creditRating = creditRating;
            this.creditLimit = creditLimit;
            this.registeredAt = registeredAt;
            this.updatedAt = updatedAt;
            this.exists = exists;
        }
    }

