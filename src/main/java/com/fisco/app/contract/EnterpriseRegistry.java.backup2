    public List<CreditLimitUpdatedEventResponse> getCreditLimitUpdatedEvents(
            TransactionReceipt transactionReceipt) {
        List<Contract.EventValuesWithLog> valueList = extractEventParametersWithLog(CREDITLIMITUPDATED_EVENT, transactionReceipt);
        ArrayList<CreditLimitUpdatedEventResponse> responses = new ArrayList<CreditLimitUpdatedEventResponse>(valueList.size());
        for (Contract.EventValuesWithLog eventValues : valueList) {
            CreditLimitUpdatedEventResponse typedResponse = new CreditLimitUpdatedEventResponse();
            typedResponse.log = eventValues.getLog();
            typedResponse.enterpriseAddr = (String) eventValues.getIndexedValues().get(0).getValue();
            typedResponse.oldLimit = (BigInteger) eventValues.getNonIndexedValues().get(0).getValue();
            typedResponse.newLimit = (BigInteger) eventValues.getNonIndexedValues().get(1).getValue();
            responses.add(typedResponse);
        }
        return responses;
    }

